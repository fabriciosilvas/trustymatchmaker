<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/trustymatchmaker/db" VERSION="20250909" COMMENT="XMLDB file for Moodle local/trustymatchmaker"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="local_trustymatchmaker" COMMENT="Default comment for local_trustymatchmaker, please edit me">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
    </TABLE>
    <TABLE NAME="collaborators" COMMENT="Default comment for the table, please edit me">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="collaboratorid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="trustymatchmaker_userid" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
        <KEY NAME="trustymatchmaker_collaboratorid" TYPE="foreign" FIELDS="collaboratorid" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
    </TABLE>
    <TABLE NAME="collaboratorvisibility" COMMENT="Default comment for the table, please edit me">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="visibility" TYPE="char" LENGTH="1" NOTNULL="true" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="trustymatchmaker_userid" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
    </TABLE>
    <TABLE NAME="local_trustymatchmaker_medals" COMMENT="Tipos de medalhas">
        <FIELDS>
            <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
            <FIELD NAME="name" TYPE="char" LENGTH="100" NOTNULL="true" SEQUENCE="false"/>
            <FIELD NAME="description" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
            <FIELD NAME="icon" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false"/>
        </FIELDS>
        <KEYS>
            <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        </KEYS>
    </TABLE>
    <TABLE NAME="local_trustymatchmaker_issued" COMMENT="Medalhas concedidas">
        <FIELDS>
            <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
            <FIELD NAME="medalid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
            <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
            <FIELD NAME="issuerid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
            <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        </FIELDS>
        <KEYS>
            <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            <KEY NAME="medalid" TYPE="foreign" FIELDS="medalid" REFTABLE="local_trustymatchmaker_medals" REFFIELDS="id"/>
            <KEY NAME="userid" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
            <KEY NAME="issuerid" TYPE="foreign" FIELDS="issuerid" REFTABLE="user" REFFIELDS="id"/>
        </KEYS>
    </TABLE>
    <TABLE NAME="local_trustymatchmaker_score_types" COMMENT="Definição das competências">
      <FIELDS>
          <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
          <FIELD NAME="name" TYPE="char" LENGTH="100" NOTNULL="true" SEQUENCE="false"/>
          <FIELD NAME="description" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
    </TABLE>
    <TABLE NAME="local_trustymatchmaker_evals" COMMENT="Registra o evento da avaliação">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Quem recebeu a avaliação"/>
        <FIELD NAME="evaluatorid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Quem avaliou"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="target_user" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
        <KEY NAME="evaluator_user" TYPE="foreign" FIELDS="evaluatorid" REFTABLE="user" REFFIELDS="id"/>
        </KEYS>
    </TABLE>
    <TABLE NAME="local_trustymatchmaker_ratings" COMMENT="As notas individuais dentro de uma avaliação">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="evalid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Vínculo com a tabela evals"/>
        <FIELD NAME="scoreid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Qual competência (Pontualidade, etc)"/>
        <FIELD NAME="value" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="A nota dada (1 a 5)"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="evaluation_link" TYPE="foreign" FIELDS="evalid" REFTABLE="local_trustymatchmaker_evals" REFFIELDS="id"/>
        <KEY NAME="score_type_link" TYPE="foreign" FIELDS="scoreid" REFTABLE="local_trustymatchmaker_score_types" REFFIELDS="id"/>
      </KEYS>
    </TABLE>
    <TABLE NAME="local_trustymatchmaker_trust_score" COMMENT="Armazena a MÉDIA CALCULADA das notas">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="scoreid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="value" TYPE="number" LENGTH="10" DECIMALS="1" NOTNULL="false" SEQUENCE="false" COMMENT="A média calculada"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="unique_score" TYPE="unique" FIELDS="userid, scoreid"/>
        <KEY NAME="score_type_link" TYPE="foreign" FIELDS="scoreid" REFTABLE="local_trustymatchmaker_score_types" REFFIELDS="id"/>
        <KEY NAME="trustymatchmaker_userid" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
    </TABLE>
  </TABLES>
</XMLDB>