<div id="novo_pedido" class="friend borda_bttm">
        <div class="friend-name-pic">
            {{{profile-picture}}}
            <h5><a href={{profile-link}}>{{collaborator-name}}</a></h5>
        </div>
        <div class="buttons d-flex">
            <div class="btn_ar">
                <button id="invite-colaboration" class="btn btn-primary">Colaborar</button>
            </div>
            
            {{#cangivemedal}}
                <div class="btn_ar ml-2">
                    <button class="btn btn-outline-warning give-medal-btn medal-trigger" data-modal-id="modal-select-medal" data-collaboratorid="{{collaborator-id}}">
                        Presentear Medalha
                    </button>
                </div>
            {{/cangivemedal}}
            
            {{^cangivemedal}}
                <div class="btn_ar ml-2">
                    <button class="btn btn-secondary" disabled title="Limite de medalhas atingido ou colaboração pendente">
                        Limite de Medalhas
                    </button>
                </div>
            {{/cangivemedal}}
            {{#contact}}
            {{/contact}}
            {{#sent}}
                <div class="btn_ar">
                    <button id="requested-friend" class="btn btn-primary" disabled>
                        Pedido de amizade enviado
                    </button>
                </div>
            {{/sent}}
            {{#received}}
                <div class="btn_ar">
                    <button id="pending-friend" class="btn btn-primary" disabled>
                        Pedido pendente
                    </button>
                </div>
            {{/received}}

            {{^contact}}
            {{^sent}}
            {{^received}}
                <div class="btn_ar">
                    <button data-friendtoadd="{{collaborator-id}}" id="invite-friend" class="btn btn-primary">
                        Adicionar aos contatos
                    </button>
                </div>
            {{/received}}
            {{/sent}}
            {{/contact}}
    </div>
</div>